// MyCoach – datový model
// Stack: Next.js 16 + Prisma 7 (driver adapter pg) + Neon Postgres
// Dokumentace: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL je v prisma.config.ts (Prisma 7). Runtime jede přes
  // driver adapter v src/lib/prisma.ts (DATABASE_URL, pooled); migrace
  // přes DIRECT_URL (bez pooleru).
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) tabulky
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // přihlášení e-mailem/heslem (Credentials)
  role          String    @default("user") // user | trainer | admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  profile           Profile?
  bodyMetrics       BodyMetric[]
  workoutLogs       WorkoutLog[]
  plansOwned        Plan[]             @relation("PlanTrainer")
  enrollments       Enrollment[]
  activities        Activity[]
  activitySchedules ActivitySchedule[]
  scheduledTasks    ScheduledTask[]
  trainings         Training[]
  packagesAuthored  Package[]          @relation("PackageAuthor")
  subscriptions     Subscription[]
  clubsOwned        Club[]             @relation("ClubOwner")
  clubMemberships   ClubMember[]
  attendances       SessionAttendance[]
  exercisesOwned    Exercise[]         @relation("ExerciseOwner")
  sounds            UserSound[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ---------------------------------------------------------------------------
// Profil a tělesné metriky (váha, % tuku) → grafy
// ---------------------------------------------------------------------------

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  heightCm  Int?
  birthYear Int?
  sex       String? // m | f | other
  goal      String? // volný popis cíle
  unit      String   @default("metric") // metric | imperial
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  weightKg  Decimal? @db.Decimal(6, 2)
  bodyFat   Decimal? @db.Decimal(5, 2)
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// Katalog: sporty, cviky, tréninkové plány
// ---------------------------------------------------------------------------

model Sport {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  icon      String?
  imageUrl  String? // fotka sportu (data URL)
  exercises Exercise[]
  plans     Plan[]
}

model Exercise {
  id         String   @id @default(cuid())
  sportId    String
  name       String
  spokenName String? // český mluvený název (syntéza řeči)
  voiceText  String? // detailní pokyn (čte se v přehrávači)
  category   String? // warmup | combinations | bag_work | sparring | conditioning…
  coop       String? // najednou|stridave|v_pulce|cele_kolo
  defaultSec Int? // navržená délka úseku v sekundách
  ownerId    String? // kdo cvik zadal (null = systémový/seedovaný)
  isPrivate  Boolean  @default(false) // soukromé → nenabízí se veřejně
  audioKey   String? // klíč MP3 instrukce v úložišti (R2) – přehraje se místo čtení
  data       Json? // volná struktura (kompatibilní s legacy drills.json)
  createdAt  DateTime @default(now())

  sport      Sport       @relation(fields: [sportId], references: [id], onDelete: Cascade)
  owner      User?       @relation("ExerciseOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  blockItems BlockItem[]

  @@index([sportId])
  @@index([sportId, category])
  @@index([ownerId])
}

model Plan {
  id          String   @id @default(cuid())
  sportId     String?
  trainerId   String? // autor plánu (role trainer)
  title       String
  description String?
  isFree      Boolean  @default(true)
  priceCents  Int? // null = zdarma
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sport       Sport?        @relation(fields: [sportId], references: [id], onDelete: SetNull)
  trainer     User?         @relation("PlanTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  sessions    PlanSession[]
  enrollments Enrollment[]

  @@index([sportId])
  @@index([trainerId])
}

model PlanSession {
  id      String @id @default(cuid())
  planId  String
  order   Int    @default(0)
  title   String
  content Json?

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  startedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([planId])
}

// ---------------------------------------------------------------------------
// Historie odcvičeného → grafy a statistiky
// ---------------------------------------------------------------------------

model WorkoutLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  sportId     String?
  planId      String?
  title       String?
  durationMin Int?
  note        String?
  data        Json?
  createdAt   DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledTask ScheduledTask?

  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// Tréninkový kalendář: aktivity, opakovaný rozvrh, naplánované úkoly
// ---------------------------------------------------------------------------

model Activity {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#18181b") // hex barva pro odlišení v kalendáři
  sportSlug String? // pokud vznikla z předpřipraveného sportu (budoucí napojení)
  createdAt DateTime @default(now())

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     ScheduledTask[]
  schedules ActivitySchedule[]
  subElement SubscriptionElement?

  @@index([userId])
}

model ActivitySchedule {
  id           String    @id @default(cuid())
  userId       String
  activityId   String
  weekdays     Int[] // 0=Ne … 6=So (JS Date.getDay); prázdné při intervalovém režimu
  intervalDays Int? // pokud vyplněno: opakování po N dnech od startDate (místo weekdays)
  startDate    DateTime  @db.Date
  endDate      DateTime? @db.Date
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity             @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tasks      ScheduledTask[]
  subElement SubscriptionElement?

  @@index([userId])
  @@index([activityId])
}

model ScheduledTask {
  id           String    @id @default(cuid())
  userId       String
  activityId   String
  scheduleId   String? // vyplněno, pokud úkol vznikl z opakovaného rozvrhu
  date         DateTime  @db.Date
  title        String?
  note         String?
  durationMin  Int?
  done         Boolean   @default(false)
  status       String    @default("open") // open | done | cancelled | postponed
  completedAt  DateTime?
  workoutLogId String?   @unique // záznam v historii vytvořený po splnění
  clubSessionId String?  // úkol vznikl z přihlášení na oddílový termín („Přijdu")
  createdAt    DateTime  @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity    Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  schedule    ActivitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  workoutLog  WorkoutLog?       @relation(fields: [workoutLogId], references: [id], onDelete: SetNull)
  clubSession ClubSession?      @relation(fields: [clubSessionId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date]) // jeden rozvrh = max 1 úkol na den (ruční mají scheduleId NULL → bez omezení)
  @@unique([userId, clubSessionId]) // max 1 kalendářní úkol na uživatele a termín
  @@index([userId, date])
  @@index([activityId])
}

// ---------------------------------------------------------------------------
// Strukturované (autorované) tréninky: Training → Block → BlockItem
// Trenér/uživatel skládá trénink ručně; kompiluje se na Segment[] pro přehrávač
// /trening (viz src/lib/trainer/compile.ts). Doplněk k procedurálnímu generátoru.
// ---------------------------------------------------------------------------

model Training {
  id          String   @id @default(cuid())
  userId      String // autor (zatím vlastní tréninky; výhledově sdílení s klientem)
  number      Int      @default(0) // pořadové číslo tréninku autora (#N)
  sportSlug   String? // číselník Sport.slug (box | …)
  title       String
  description String?
  difficulty  String? // zacatecnik | mirne_pokrocily | pokrocily | expert
  imageUrl    String? // logo/obrázek tréninku (data URL)
  targetMin   Int? // cílová délka v minutách (orientační)
  isPublic    Boolean  @default(false) // veřejný → ostatní si ho najdou a přidají
  prepareSec  Int      @default(10) // délka úvodní přípravy
  betweenBlocksSec Int @default(60) // pauza mezi bloky (zvlášť od pauz v bloku)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks       Block[]
  clubSessions ClubSession[]

  @@index([userId])
  @@index([isPublic])
}

model Block {
  id         String   @id @default(cuid())
  trainingId String
  order      Int      @default(0)
  title      String
  category   String? // warmup|combinations|bag_work|sparring|conditioning – barva/štítek
  rounds     Int      @default(1) // kolikrát blok zopakovat
  prepareSec Int      @default(0) // příprava před blokem (0 = žádná; např. čas na bandáže)
  restSec    Int      @default(60) // pauza mezi koly bloku (0 = bez pauzy)
  restBetweenItems Boolean @default(false) // pauza i mezi jednotlivými cviky v kole
  // Aktivní pauza mezi koly: místo vydýchání kondiční cvik (denormalizováno z Exercise)
  restName       String?
  restSpokenName String?
  restVoiceText  String?
  restAudioKey   String?
  createdAt  DateTime @default(now())

  training Training    @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  items    BlockItem[]

  @@index([trainingId])
}

model BlockItem {
  id          String  @id @default(cuid())
  blockId     String
  order       Int     @default(0)
  name        String
  spokenName  String? // český mluvený název pro syntézu řeči
  voiceText   String? // detailní pokyn čtený na začátku úseku
  coop        String? // najednou|stridave|v_pulce|cele_kolo
  durationSec Int     @default(180)
  audioKey    String? // zkopírovaný klíč MP3 instrukce z cviku (přehraje se místo čtení)
  exerciseId  String? // provenience z číselníku Exercise (lookup dle sportu)

  block    Block     @relation(fields: [blockId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@index([blockId])
  @@index([exerciseId])
}

// ---------------------------------------------------------------------------
// Balíčky (programy) a odběry
// Balíček = autorovaný, kategorizovaný bundle prvků s navrženou frekvencí
// (např. „Ženská krása" → kadeřník, kosmetika, pedikúra). Uživatel si dá odběr,
// přizpůsobí prvky/frekvenci a po potvrzení se mu vygenerují do kalendáře
// (Activity + intervalový ActivitySchedule). Zrušení odběru je z kalendáře smaže.
// ---------------------------------------------------------------------------

model Package {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String?
  category    String? // pro filtr ve vyhledávání (krasa | fitness | zdravi | …)
  tags        String[] // volné štítky pro vyhledávání
  icon        String? // emoji
  color       String   @default("#18181b")
  authorId    String? // autor (role trainer/admin); null = systémový
  isFree      Boolean  @default(true)
  priceCents  Int? // null = zdarma (platby zatím neřešíme)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author        User?            @relation("PackageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  elements      PackageElement[]
  subscriptions Subscription[]

  @@index([category])
  @@index([published])
}

model PackageElement {
  id                  String  @id @default(cuid())
  packageId           String
  order               Int     @default(0)
  name                String // „Kadeřník"
  note                String? // krátký popis
  color               String  @default("#18181b")
  defaultIntervalDays Int     @default(28) // navržená frekvence (po kolika dnech)
  optional            Boolean @default(true) // smí uživatel vypnout

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  packageId String
  active    Boolean  @default(true)
  startDate DateTime @db.Date
  createdAt DateTime @default(now())

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  package  Package               @relation(fields: [packageId], references: [id], onDelete: Cascade)
  elements SubscriptionElement[]

  @@unique([userId, packageId])
  @@index([userId])
}

// Katalog prvků (lookup) – nabídka, ze které si uživatel přidává další prvky
// do svého odběru. Mají navrženou frekvenci; nepatří k žádné konkrétní šabloně.
model ElementPreset {
  id                  String   @id @default(cuid())
  name                String
  note                String?
  color               String   @default("#18181b")
  defaultIntervalDays Int      @default(28)
  category            String?
  createdAt           DateTime @default(now())

  @@index([category])
}

model SubscriptionElement {
  id             String  @id @default(cuid())
  subscriptionId String
  elementId      String? // odkaz na zdrojový PackageElement (volné, kvůli změnám balíčku)
  name           String
  color          String  @default("#18181b")
  enabled        Boolean @default(true)
  intervalDays   Int     @default(28)
  activityId     String? @unique // vygenerovaná aktivita v kalendáři
  scheduleId     String? @unique // vygenerovaný intervalový rozvrh

  subscription Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  activity     Activity?         @relation(fields: [activityId], references: [id], onDelete: SetNull)
  schedule     ActivitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
}

// ---------------------------------------------------------------------------
// Oddíly (kluby/skupiny): rozvrh tréninků, členství + pozvánky, termíny,
// docházka. Termín bez účastníků = Zrušeno; trenér termín potvrzuje.
// ---------------------------------------------------------------------------

model Club {
  id        String   @id @default(cuid())
  ownerId   String // správce oddílu
  name      String
  slug      String   @unique
  logoUrl   String? // editovatelné logo (data URL)
  address   String? // adresa tělocvičny
  sportSlug String?
  isPublic  Boolean  @default(false) // veřejně dohledatelný
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User               @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  rules    ClubScheduleRule[]
  members  ClubMember[]
  invites  ClubInvite[]
  sessions ClubSession[]

  @@index([ownerId])
  @@index([isPublic])
}

model ClubScheduleRule {
  id        String   @id @default(cuid())
  clubId    String
  weekdays  Int[] // 0=Ne … 6=So
  startMin  Int // začátek (minuty od půlnoci)
  endMin    Int // konec
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  club     Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sessions ClubSession[]

  @@index([clubId])
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String
  userId   String
  role     String   @default("member") // owner | trainer | member
  joinedAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
}

model ClubInvite {
  id          String   @id @default(cuid())
  clubId      String
  email       String // pozvánka podle e-mailu
  role        String   @default("member") // member | trainer (role po přijetí)
  status      String   @default("pending") // pending | accepted | declined
  invitedById String?
  createdAt   DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, email])
  @@index([email])
}

model ClubSession {
  id               String   @id @default(cuid())
  clubId           String
  ruleId           String? // z jakého rozvrhu vznikl
  date             DateTime @db.Date
  startMin         Int
  endMin           Int
  trainingId       String? // přidělený trénink na tento termín
  trainerConfirmed Boolean  @default(false) // potvrzeno trenérem
  canceled         Boolean  @default(false) // ručně zrušeno správcem
  createdAt        DateTime @default(now())

  club          Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  rule          ClubScheduleRule?   @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  training      Training?           @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  attendances   SessionAttendance[]
  calendarTasks ScheduledTask[]

  @@unique([clubId, date, startMin])
  @@index([clubId, date])
}

// Vlastní zvukové pokyny uživatele (technické cue), víc MP3 na typ → náhodně.
model UserSound {
  id        String   @id @default(cuid())
  userId    String
  type      String // start | round_start | round_end | rest | half_swap | switch | countdown | finish
  audioKey  String // klíč MP3 v úložišti (R2, prefix mycoach/sounds/)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model SessionAttendance {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  status    String   @default("going") // going | excused (omluveno)
  createdAt DateTime @default(now())

  session ClubSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
}
