// MyCoach – datový model
// Stack: Next.js 16 + Prisma 7 (driver adapter pg) + Neon Postgres
// Dokumentace: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL je v prisma.config.ts (Prisma 7). Runtime jede přes
  // driver adapter v src/lib/prisma.ts (DATABASE_URL, pooled); migrace
  // přes DIRECT_URL (bez pooleru).
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) tabulky
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // přihlášení e-mailem/heslem (Credentials)
  role          String    @default("user") // user | trainer | admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  profile           Profile?
  bodyMetrics       BodyMetric[]
  workoutLogs       WorkoutLog[]
  plansOwned        Plan[]             @relation("PlanTrainer")
  enrollments       Enrollment[]
  activities        Activity[]
  activitySchedules ActivitySchedule[]
  scheduledTasks    ScheduledTask[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ---------------------------------------------------------------------------
// Profil a tělesné metriky (váha, % tuku) → grafy
// ---------------------------------------------------------------------------

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  heightCm  Int?
  birthYear Int?
  sex       String? // m | f | other
  goal      String? // volný popis cíle
  unit      String   @default("metric") // metric | imperial
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  weightKg  Decimal? @db.Decimal(6, 2)
  bodyFat   Decimal? @db.Decimal(5, 2)
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// Katalog: sporty, cviky, tréninkové plány
// ---------------------------------------------------------------------------

model Sport {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  icon      String?
  exercises Exercise[]
  plans     Plan[]
}

model Exercise {
  id         String   @id @default(cuid())
  sportId    String
  name       String
  spokenName String? // český mluvený název (syntéza řeči)
  category   String? // warmup | combinations | bag_work | sparring | conditioning…
  data       Json? // volná struktura (kompatibilní s legacy drills.json)
  createdAt  DateTime @default(now())

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@index([sportId])
}

model Plan {
  id          String   @id @default(cuid())
  sportId     String?
  trainerId   String? // autor plánu (role trainer)
  title       String
  description String?
  isFree      Boolean  @default(true)
  priceCents  Int? // null = zdarma
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sport       Sport?        @relation(fields: [sportId], references: [id], onDelete: SetNull)
  trainer     User?         @relation("PlanTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  sessions    PlanSession[]
  enrollments Enrollment[]

  @@index([sportId])
  @@index([trainerId])
}

model PlanSession {
  id      String @id @default(cuid())
  planId  String
  order   Int    @default(0)
  title   String
  content Json?

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  startedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([planId])
}

// ---------------------------------------------------------------------------
// Historie odcvičeného → grafy a statistiky
// ---------------------------------------------------------------------------

model WorkoutLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  sportId     String?
  planId      String?
  title       String?
  durationMin Int?
  note        String?
  data        Json?
  createdAt   DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledTask ScheduledTask?

  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// Tréninkový kalendář: aktivity, opakovaný rozvrh, naplánované úkoly
// ---------------------------------------------------------------------------

model Activity {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#18181b") // hex barva pro odlišení v kalendáři
  sportSlug String? // pokud vznikla z předpřipraveného sportu (budoucí napojení)
  createdAt DateTime @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     ScheduledTask[]
  schedules ActivitySchedule[]

  @@index([userId])
}

model ActivitySchedule {
  id         String    @id @default(cuid())
  userId     String
  activityId String
  weekdays   Int[] // 0=Ne … 6=So (JS Date.getDay)
  startDate  DateTime  @db.Date
  endDate    DateTime? @db.Date
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tasks    ScheduledTask[]

  @@index([userId])
  @@index([activityId])
}

model ScheduledTask {
  id           String    @id @default(cuid())
  userId       String
  activityId   String
  scheduleId   String? // vyplněno, pokud úkol vznikl z opakovaného rozvrhu
  date         DateTime  @db.Date
  title        String?
  note         String?
  durationMin  Int?
  done         Boolean   @default(false)
  completedAt  DateTime?
  workoutLogId String?   @unique // záznam v historii vytvořený po splnění
  createdAt    DateTime  @default(now())

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  schedule   ActivitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  workoutLog WorkoutLog?       @relation(fields: [workoutLogId], references: [id], onDelete: SetNull)

  @@unique([scheduleId, date]) // jeden rozvrh = max 1 úkol na den (ruční mají scheduleId NULL → bez omezení)
  @@index([userId, date])
  @@index([activityId])
}
